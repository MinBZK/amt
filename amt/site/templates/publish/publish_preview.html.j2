
{% extends 'layouts/base.html.j2' %}
{% from "macros/editable_macros.html.j2" import editable with context %}
{% import "macros/tabs.html.j2" as tabs with context %}
{% block title %}{{ algorithm.name }} | AMT{% endblock %}
{% block content %}
<c-max-width-layout size="lg">
    <c-grid columns="two" division="1fr 3fr">
        <c-progress-tracker :steps="steps"/>
        <div>
            <c-heading type="h1" class="rvo-layout-margin-vertical--xl">Preview & controleren</c-heading>

            <c-card outline="true" class="rvo-layout-margin-vertical--xl">
                <c-heading type="h2">
                    {{ publication_model.name }}
                </c-heading>
                <c-grid columns="two">
                    <div>
                        <c-link href="#">{{ publication_model.organization }}</c-link>
                        <c-p>
                            {{ publication_model.description_short }}
                        </c-p>
                    </div>
                    <div>
                        <c-p text-style="bold">Publicatiecategorie</c-p>
                        <c-p>{{ publication_model.publication_category }}</c-p>
                        <c-p text-style="bold">Impacttoetsen</c-p>
                        <c-p>{{ publication_model.impacttoetsen_grouping | map(attribute='title') | join(', ') }}</c-p>
                        <c-p text-style="bold">Status</c-p>
                        <c-p>{{ publication_model.status }}</c-p>
                    </div>
                </c-grid>
            </c-card>
            <c-tabs>
                <c-tab-item
                    @click="applyRules('#tab-content-container > *: +display-none; #{id}-content: -display-none; siblings > a: -rvo-link--active -rvo-tabs__item-link--active; self > a: +rvo-link--active +rvo-tabs__item-link--active', event, { preventDefault: true, stopPropagation: true })"
                    id="tab1" href="#" label="Algemene informatie" :selected="true"/>
                <c-tab-item
                    @click="applyRules('#tab-content-container > *: +display-none; #{id}-content: -display-none; siblings > a: -rvo-link--active -rvo-tabs__item-link--active; self > a: +rvo-link--active +rvo-tabs__item-link--active', event, { preventDefault: true, stopPropagation: true })"
                    id="tab2" href="#" label="Verantwoord gebruik"/>
                <c-tab-item
                    @click="applyRules('#tab-content-container > *: +display-none; #{id}-content: -display-none; siblings > a: -rvo-link--active -rvo-tabs__item-link--active; self > a: +rvo-link--active +rvo-tabs__item-link--active', event, { preventDefault: true, stopPropagation: true })"
                    id="tab3" href="#" label="Werking"/>
            </c-tabs>
            <div id="tab-content-container">
                <div id="tab1-content">
                    <c-table>
                        <colgroup>
                            <col style="width: 20%">
                            <col style="width: 80%">
                        </colgroup>
                        <c-tr>
                            <c-td>
                                <c-strong>Thema</c-strong>
                            </c-td>
                            <c-td>...</c-td>
                        </c-tr>
                        <c-tr>
                            <c-td>Begindatum</c-td>
                            <c-td>{{ publication_model.begin_date }}</c-td>
                        </c-tr>
                        <c-tr>
                            <c-td>Contactgegevens </c-td>
                            <c-td>{{ publication_model.contact_email }}</c-td>
                        </c-tr>
                    </c-table>
                </div>
                <div id="tab2-content" class="display-none">Sorry, under construction...</div>
                <div id="tab3-content" class="display-none">Sorry, ook under construction...</div>
            </div>

            <c-alert kind="warning" heading="Warning">
                <c-p>Tijdens ontwikkeling van deze feature, zorgt de volgende stap er voor dat het
                algoritme gelijk in het register staat. Normaal moet deze vrijgegeven worden
                door de mensen van het register.</c-p>
            </c-alert>
            
            <br/>
            <c-button @click="window.location='./confirm'" kind="primary">Publiceren</c-button>
            {#            {{ publication_model_json }}#}
        </div>
    </c-grid>
</c-max-width-layout>
{% endblock %}